APP_NAME="Chama Digital"
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:key=
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chama_db
DB_USERNAME=root
DB_PASSWORD=

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@chama.local"
MAIL_FROM_NAME="${APP_NAME}"

SESSION_DRIVER=database
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
