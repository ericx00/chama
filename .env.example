APP_NAME="Chama Digital"
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Default to SQLite for zero-configuration local setup.
# For production, switch DB_CONNECTION=mysql and set the credentials below.
DB_CONNECTION=sqlite
DB_FOREIGN_KEYS=true

# MySQL settings (used when DB_CONNECTION=mysql).
# Leave DB_DATABASE unset/commented when using SQLite so the
# config falls back to database_path('database.sqlite').
DB_HOST=127.0.0.1
DB_PORT=3306
# DB_DATABASE=chama_db
DB_USERNAME=root
DB_PASSWORD=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@chama.local"
MAIL_FROM_NAME="${APP_NAME}"

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
